<section class="bg-deep text-cream py-16 lg:py-24">
  <div class="max-w-screen-xl mx-auto px-4 lg:px-8 text-center">
    <h1 class="font-display text-4xl lg:text-6xl font-normal leading-tight">{{ section.settings.heading | escape }}</h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="font-body text-xs uppercase tracking-widest text-cream/60 mt-4">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}
  </div>
</section>

<section class="max-w-screen-xl mx-auto px-4 lg:px-8 py-12 lg:py-16">
  {%- assign posts = shop.metaobjects.social_post.values -%}

  {%- if posts.size > 0 -%}
    <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {%- for post in posts -%}
        <div class="relative group aspect-square overflow-hidden bg-sand">

          {%- if post.image != blank -%}
            {{ post.image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-500', loading: 'lazy', alt: post.caption | escape }}
          {%- else -%}
            <div class="w-full h-full bg-sand"></div>
          {%- endif -%}

          <div class="absolute inset-0 bg-deep/60 flex flex-col items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <p class="font-body text-xs text-cream text-center px-4 line-clamp-2">{{ post.caption | escape }}</p>
            {%- if post.product != blank -%}
              <a href="{{ post.product.url | escape }}" class="font-body text-xs uppercase tracking-widest text-cream border border-cream/50 px-4 py-2 hover:bg-cream hover:text-deep transition-colors">Shop This Look</a>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="py-24 text-center">
      <h2 class="font-display text-3xl font-normal text-deep">Nothing to see yet.</h2>
      <p class="font-body text-sm text-mid leading-relaxed mt-4">Tag us @soleilnoir to be featured here.</p>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Social UGC Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As Seen On You"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real bodies. Real styles. All Soleil Noir."
    }
  ],
  "presets": [
    {
      "name": "Social UGC Gallery"
    }
  ]
}
{% endschema %}
