<style>
  .social-feed-scroll::-webkit-scrollbar { display: none; }
  .social-feed-scroll { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<section class="bg-cream py-12 md:py-16">
  <div class="max-w-screen-xl mx-auto px-4">
    <h2 class="font-display text-3xl md:text-4xl text-deep text-center mb-8">
      {{ section.settings.heading }}
    </h2>

    {%- assign posts = shop.metaobjects.social_post.values -%}

    {%- if posts.size > 0 -%}
      <div class="social-feed-scroll flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4" style="-webkit-overflow-scrolling: touch;">
        {%- for post in posts -%}
          <div class="relative group w-64 h-64 flex-shrink-0 snap-start overflow-hidden">

            {%- if post.image != blank -%}
              {{ post.image | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy', alt: post.caption }}
            {%- else -%}
              <div class="w-full h-full bg-sand"></div>
            {%- endif -%}

            <div class="absolute inset-0 bg-deep/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              {%- if post.product != blank -%}
                <a href="{{ post.product.url }}" class="text-center px-4">
                  <span class="font-body text-xs tracking-widest uppercase text-cream">Shop {{ post.product.title }}</span>
                  <span class="text-coral"> &rarr;</span>
                </a>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="text-mid font-body text-sm text-center col-span-4">Add social posts in Shopify admin under Content &rarr; Metaobjects &rarr; Social Post.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Social Feed Strip",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "As Seen On"
    }
  ],
  "presets": [
    {
      "name": "Social Feed Strip"
    }
  ]
}
{% endschema %}
