<!-- Page Hero (D-10) -->
<section class="bg-deep text-cream py-16 lg:py-24">
  <div class="max-w-screen-xl mx-auto px-4 text-center">
    <h1 class="font-display text-4xl lg:text-6xl font-normal leading-tight text-center">
      {{ section.settings.heading | escape }}
    </h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="font-body text-xs uppercase tracking-widest text-cream/60 mt-4 text-center">
        {{ section.settings.subtitle | escape }}
      </p>
    {%- endif -%}
  </div>
</section>

<!-- Content Column (D-09) -->
<section class="max-w-2xl mx-auto px-4 py-16">

  <!-- Body copy -->
  {%- if section.settings.body != blank -%}
    <p class="font-body text-sm text-mid leading-relaxed">{{ section.settings.body | escape }}</p>
  {%- endif -%}

  <!-- Payment icons strip -->
  {%- if section.blocks.size > 0 -%}
    <div class="flex flex-wrap gap-6 items-center mt-6">
      {%- for block in section.blocks -%}
        {%- if block.type == 'payment_icon' -%}
          <div {{ block.shopify_attributes }}>
            {%- if block.settings.icon_image != blank -%}
              {{ block.settings.icon_image | image_url: width: 120 | image_tag: class: 'h-8 w-auto', loading: 'lazy', alt: block.settings.label | escape }}
            {%- else -%}
              <span class="font-body text-xs uppercase tracking-widest text-mid">{{ block.settings.label | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Trust badge strip -->
  <div class="font-body text-xs uppercase tracking-widest text-mid flex flex-wrap gap-8 items-center mt-6">
    <span>SSL Encrypted</span>
    <span>PCI-DSS Level 1</span>
    <span>US-Based Business</span>
  </div>

</section>

{% schema %}
{
  "name": "Payment Info Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Payment & Security"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Safe, simple, US checkout — always."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body copy"
    }
  ],
  "blocks": [
    {
      "type": "payment_icon",
      "name": "Payment Icon",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Payment method label"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image (optional)"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{ "name": "Payment Info" }]
}
{% endschema %}
