<div class="flex flex-col md:flex-row min-h-[60vh] md:min-h-[80vh]">

  <!-- Left panel: image (55% desktop) -->
  <div class="relative w-full md:w-[55%] aspect-[4/3] md:aspect-auto">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
    {%- else -%}
      <div class="w-full h-full bg-sand"></div>
    {%- endif -%}
  </div>

  <!-- Right panel: text (45% desktop) -->
  <div class="flex flex-col justify-center bg-deep px-8 py-16 md:px-12 md:py-20 lg:px-16 w-full md:w-[45%]">
    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-normal leading-tight text-cream">
      {{ section.settings.heading }}
    </h1>
    <p class="font-body text-lg md:text-xl font-normal tracking-wide text-cream mt-4">
      {{ section.settings.subheading }}
    </p>
    <a
      href="{{ section.settings.cta_url }}"
      class="inline-block mt-8 bg-coral text-cream font-body text-sm font-semibold tracking-widest uppercase px-6 py-3 hover:bg-coral/90 transition-colors duration-200 focus:ring-2 focus:ring-coral focus:ring-offset-2 focus:outline-none active:bg-coral/80 active:scale-[0.98] transition-transform duration-100"
    >
      {{ section.settings.cta_label }}
    </a>
  </div>

</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "[PLACEHOLDER — owner provides]"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheadline",
      "default": "[PLACEHOLDER — owner provides]"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
