<section id="testimonial-section" class="bg-sand py-16 md:py-20"
  data-section-type="testimonials">

  <div class="max-w-screen-xl mx-auto px-4">

    <h2 class="font-display text-3xl md:text-4xl text-deep text-center mb-12">
      {{ section.settings.heading }}
    </h2>

    <!-- Quote display area -->
    <div class="max-w-2xl mx-auto text-center">

      <span class="font-display text-6xl leading-none text-gold select-none">&ldquo;</span>

      <blockquote
        id="testimonial-quote"
        class="font-display text-2xl md:text-3xl font-normal italic leading-relaxed text-deep transition-opacity duration-500"
      >
        {%- if section.blocks.size > 0 -%}
          {{ section.blocks[0].settings.quote }}
        {%- endif -%}
      </blockquote>

      <span class="font-display text-6xl leading-none text-gold select-none">&rdquo;</span>

      <p
        id="testimonial-author"
        class="font-body text-xs font-semibold tracking-widest uppercase text-deep mt-4 transition-opacity duration-500"
      >
        {%- if section.blocks.size > 0 -%}
          {{ section.blocks[0].settings.author }}
          {%- if section.blocks[0].settings.location != blank -%}
            &middot;
            <span class="font-body text-xs text-mid font-normal normal-case tracking-normal">
              {{ section.blocks[0].settings.location }}
            </span>
          {%- endif -%}
        {%- endif -%}
      </p>

    </div>

    <!-- Dot indicators — populated by JS -->
    <div
      id="testimonial-dots"
      class="flex justify-center gap-2 mt-8"
      data-count="{{ section.blocks.size }}"
    ></div>

  </div>

  <!-- JSON data handoff: block data passed to JS, all fields escaped via Liquid json filter (T-03-14) -->
  <script type="application/json" id="testimonial-data">
    {%- if section.blocks.size > 0 -%}
      [{% for block in section.blocks %}{"quote":{{ block.settings.quote | json }},"author":{{ block.settings.author | json }},"location":{{ block.settings.location | default: '' | json }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
    {%- else -%}
      []
    {%- endif -%}
  </script>

  <!-- ES module: load the carousel script then call init() -->
  <script type="module" src="{{ 'testimonial-carousel.js' | asset_url }}" defer></script>
  <script type="module">
    import { init } from {{ 'testimonial-carousel.js' | asset_url | json }};
    document.addEventListener('DOMContentLoaded', function () { init(); });
  </script>

</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "What She Said"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location (optional)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}
