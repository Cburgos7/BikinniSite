<footer class="bg-deep text-cream py-12 mt-auto">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8">

    <!-- Column 1: Brand -->
    <div>
      <p class="font-display text-xl">{{ shop.name }}</p>
      <p class="font-body text-mid text-sm mt-2">Daring swim. Inclusive sizing.</p>
    </div>

    <!-- Column 2: Shop -->
    <div>
      <h3 class="font-body uppercase tracking-widest text-sm mb-4">Shop</h3>
      {%- if collections['new-in'].id -%}
        <a href="{{ collections['new-in'].url }}" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">New In</a>
      {%- endif -%}
      {%- if collections['bikinis'].id -%}
        <a href="{{ collections['bikinis'].url }}" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">Bikinis</a>
      {%- endif -%}
      {%- if collections['lingerie'].id -%}
        <a href="{{ collections['lingerie'].url }}" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">Lingerie</a>
      {%- endif -%}
      {%- if collections['sale'].id -%}
        <a href="{{ collections['sale'].url }}" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">Sale</a>
      {%- endif -%}
    </div>

    <!-- Column 3: Help -->
    <div>
      <h3 class="font-body uppercase tracking-widest text-sm mb-4">Help</h3>
      {%- if pages['faq'].id -%}
        <a href="{{ pages['faq'].url }}" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">FAQ</a>
      {%- endif -%}
      {%- if pages['contact'].id -%}
        <a href="{{ pages['contact'].url }}" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">Contact</a>
      {%- endif -%}
      {%- if pages['size-guide'].id -%}
        <a href="{{ pages['size-guide'].url }}" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">Size Guide</a>
      {%- endif -%}
    </div>

    <!-- Column 4: Legal -->
    <div>
      <h3 class="font-body uppercase tracking-widest text-sm mb-4">Legal</h3>
      <a href="/policies/privacy-policy" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">Privacy</a>
      <a href="/policies/terms-of-service" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">Terms</a>
      <a href="/policies/refund-policy" class="block font-body text-sm text-mid hover:text-cream transition-colors py-1">Returns</a>
    </div>

  </div>

  <!-- Copyright -->
  <div class="mt-10 border-t border-mid/30 pt-6 text-center font-body text-xs text-mid">
    &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
