<section class="bg-cream py-12 md:py-16">
  <div class="max-w-screen-xl mx-auto px-4">

    <h2 class="font-display text-3xl md:text-4xl text-deep text-center mb-8 md:mb-12">
      {{ section.settings.heading }}
    </h2>

    {%- if section.settings.collection != blank -%}
      {%- assign new_products = section.settings.collection.products | limit: section.settings.product_count -%}

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        {%- for product in new_products -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>

      <div class="mt-8 text-center">
        <a href="{{ section.settings.collection.url }}" class="font-body text-sm font-semibold tracking-widest uppercase text-coral hover:text-deep transition-colors">
          {{ section.settings.view_all_label }}
        </a>
      </div>

    {%- else -%}
      <p class="text-center text-mid">Configure a collection in theme editor settings.</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "New Arrivals"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 2,
      "max": 8,
      "step": 2,
      "default": 4
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all link label",
      "default": "View All New Arrivals →"
    }
  ],
  "presets": [{ "name": "New Arrivals" }]
}
{% endschema %}
