<div class="bg-deep text-cream text-center py-2 text-sm font-body tracking-wider">
  {%- if section.settings.text != blank -%}
    {{ section.settings.text }}
  {%- else -%}
    Free shipping on orders over ${{ section.settings.free_shipping_threshold }} &middot; New drops weekly &middot; US-based
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "info": "Leave blank to show the free shipping message automatically."
    },
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold ($)",
      "default": 75
    }
  ],
  "presets": [{ "name": "Announcement Bar" }]
}
{% endschema %}
