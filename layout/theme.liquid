<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0d0a08">

  <title>
    {%- if page_title -%}
      {{ page_title }}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Font preloads -->
  <link rel="preload" as="font" type="font/woff2"
    href="{{ 'cormorant-garamond-regular.woff2' | asset_url }}"
    crossorigin="anonymous">
  <link rel="preload" as="font" type="font/woff2"
    href="{{ 'barlow-condensed-regular.woff2' | asset_url }}"
    crossorigin="anonymous">

  <!-- Stylesheet -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <!-- Font faces -->
  {%- render 'font-faces' -%}

  {{ content_for_header }}

  {%- if settings.klaviyo_company_id != blank -%}
    <script async type="text/javascript"
      src="https://static.klaviyo.com/onsite/js/klaviyo.js?company_id={{ settings.klaviyo_company_id }}">
    </script>
  {%- endif -%}

  {%- if settings.ga4_measurement_id != blank -%}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.ga4_measurement_id }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ settings.ga4_measurement_id }}', { send_page_view: true });
    </script>

    <script id="ga4-page-data" type="application/json">
      {
        "pageType": {{ request.page_type | json }},
        "currency": "USD"
        {%- if product -%}
        ,"product": {
          "id": {{ product.id | json }},
          "name": {{ product.title | json }},
          "brand": {{ shop.name | json }},
          "category": {{ product.type | json }},
          "variant": {{ product.selected_or_first_available_variant.id | json }},
          "price": {{ product.selected_or_first_available_variant.price | money_without_currency | json }},
          "sku": {{ product.selected_or_first_available_variant.sku | json }},
          "imageUrl": {{ product.featured_image | img_url: '600x' | json }}
        }
        {%- endif -%}
        {%- if collection -%}
        ,"collection": {
          "id": {{ collection.id | json }},
          "name": {{ collection.title | json }},
          "products": [
            {%- for p in collection.products limit: 50 -%}
              {
                "id": {{ p.id | json }},
                "name": {{ p.title | json }},
                "price": {{ p.price | money_without_currency | json }},
                "position": {{ forloop.index }},
                "category": {{ p.type | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        }
        {%- endif -%}
      }
    </script>
  {%- endif -%}
</head>

<body
  class="bg-cream text-deep font-body pt-16"
  data-customer-email="{{ customer.email | escape }}"
  data-customer-id="{{ customer.id }}"
  data-klaviyo-company-id="{{ settings.klaviyo_company_id | escape }}"
  data-ga4-id="{{ settings.ga4_measurement_id | escape }}"
>
  <!-- Custom cursor (hidden on touch devices) -->
  <div id="custom-cursor"
    class="pointer-events-none fixed top-0 left-0 z-[9999] w-4 h-4 rounded-full bg-coral mix-blend-difference will-change-transform hidden md:block"
    aria-hidden="true"></div>

  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-deep text-cream px-4 py-2 z-50">
    Skip to content
  </a>

  {% section 'announcement-bar' %}
  {% section 'header' %}
  {% section 'cart-drawer' %}

  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script type="module" src="{{ 'custom-cursor.js' | asset_url }}"></script>

  {%- if settings.klaviyo_company_id != blank -%}
    <script type="module" src="{{ 'klaviyo.js' | asset_url }}"></script>
  {%- endif -%}

  {%- if settings.ga4_measurement_id != blank -%}
    <script type="module" src="{{ 'ref-capture.js' | asset_url }}"></script>
    <script type="module" src="{{ 'ga4.js' | asset_url }}"></script>
  {%- endif -%}

  {% section 'cookie-consent' %}
</body>
</html>
